# 测试环境 MinIO 覆盖配置
# ------------------------------------------------------------------
# 用途：docker-compose.yml 里 MinIO 的对外 URL 和端口绑定都已参数化，
# 本地跑什么都不用配（吃 localhost / 127.0.0.1 默认值）；测试环境通过本文件覆盖。
#
# 用法（从项目根 nest-admin/ 执行）：
#   docker compose -f docker/docker-compose.yml --env-file .env.test up -d
# 或：把下面几项直接写进项目根的 .env（测试机自用那份），从根目录直接 up。
# ------------------------------------------------------------------

# 端口绑定地址：
#   127.0.0.1 = 仅本机访问（本地默认，最安全）
#   0.0.0.0   = 对宿主机所有网卡暴露（测试环境直连端口用这个）
MINIO_HOST_BIND=0.0.0.0

# MinIO S3 API 对外地址 —— 生成预签名 URL（前端下载/上传链接）用。
# 把 47.x.x.x 换成测试机的内网/公网 IP（或测试机hostname），端口对应宿主机映射端口。
MINIO_SERVER_URL=http://47.122.112.109:9000

# MinIO 控制台对外地址 —— 浏览器登录控制台后的回跳地址，9001 对应 console。
MINIO_BROWSER_REDIRECT_URL=http://47.122.112.109:9001

# Redis / RabbitMQ 管理端口绑定（可选）
# 仅当测试环境需要从外部访问 Redis / RabbitMQ 管理界面时才放开为 0.0.0.0。
REDIS_HOST_BIND=0.0.0.0
RABBITMQ_HOST_BIND=0.0.0.0
