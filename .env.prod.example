# 生产环境配置模板 —— 复制为 .env.prod 并填入真实值
# 用法: ./deploy.sh prod
# ⚠️ 真实 .env.prod 含密钥,已被 .gitignore 忽略,切勿提交。

# Database (生产库)
DATABASE_URL=postgresql://USER:PASSWORD@PROD_DB_HOST:5432/app_db?schema=public&connect_timeout=30&pool_timeout=15

DB_SYNC=false
DB_LOGGING=false

# JWT (至少 32 字符,生产请用强随机串)
JWT_EXPIRES_IN=2d
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars

# Redis
# 注意:应用以 --network host 运行。若 redis 端口已发布到宿主机,用 localhost;
#       若走 docker 网络名,确保该名字在 host 网络下可解析(如 /etc/hosts)。
REDIS_URL=redis://USER:PASSWORD@PROD_REDIS_HOST:6379
REDIS_HOST=PROD_REDIS_HOST
REDIS_PORT=6379
REDIS_PASSWORD=PROD_REDIS_PASSWORD
REDIS_DB=0

# MinIO
MINIO_HOST_BIND=0.0.0.0
MINIO_ENDPOINT=PROD_MINIO_HOST
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_SERVER_URL=http://PROD_PUBLIC_IP:9000
MINIO_BROWSER_REDIRECT_URL=http://PROD_PUBLIC_IP:9001

# Email
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=20971520

# Server
PORT=3000
GLOBAL_PREFIX=api

# WebSocket
WS_PORT=3001

# Queue
BULL_REDIS_URL=redis://PROD_REDIS_HOST:6379

# Environment
NODE_ENV=production
SSL=false

# Logging
LOG_LEVEL=info
LOG_DIR=logs
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_HEALTH_LOG_ENABLED=false
LOG_DEPENDENCY_CHECK_INTERVAL_MS=30000
LOG_MAX_FILE_SIZE_MB=20
LOG_RETENTION_DAYS=30

# 依赖服务版本 tag
POSTGRES_VERSION_TAG=15
MINIO_VERSION_TAG=latest
REDIS_VERSION_TAG=7
RABBITMQ_VERSION_TAG=3-management

# 依赖服务账号
ADMIN_LOGIN=admin
ADMIN_PASSWORD=replace-with-strong-password

# AI 模型
MODEL_NAME=qwen-plus
OPENAI_API_KEY=
EMBEDDINGS_MODEL_NAME=text-embedding-v3
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODERATION_ENABLED=true
AI_MODERATION_MODEL=
AI_MODERATION_TIMEOUT_MS=5000
AI_MODERATION_MAX_CHARACTERS=4000
AI_MODERATION_MODE=async
AI_MODERATION_POLICY_VERSION=v1
AI_MODERATION_ACTIONS_ENABLED=false
AI_MODERATION_ENFORCEMENT_ENABLED=false
AI_MODERATION_VIOLATION_WINDOW_MS=86400000
AI_MODERATION_WARNING_SCORE=3
AI_MODERATION_MUTE_SCORE=6
AI_MODERATION_MUTE_DURATION_MS=600000
CHAT_MODERATION_PUBLISHER_ENABLED=true
CHAT_MODERATION_CONSUMER_ENABLED=true
CHAT_MODERATION_RETRY_DELAY_MS=10000
CHAT_MODERATION_MAX_RETRY=3
CHAT_MODERATION_PREFETCH=5
MODERATION_OUTBOX_POLL_MS=1000
MODERATION_OUTBOX_BATCH_SIZE=50
MODERATION_OUTBOX_LOCK_MS=30000
MODERATION_OUTBOX_MAX_ATTEMPTS=10
MODERATION_OUTBOX_RETENTION_DAYS=7
AI_RATE_LIMIT_WINDOW_MS=5000
AI_RATE_LIMIT_MAX_REQUESTS=1
ALLOWED_PATHS=
