# Database
DATABASE_URL="postgresql://username:password@localhost:5432/nest_admin"

# JWT
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# File Upload
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE=20971520  # 20MB

# Server
PORT=3000
GLOBAL_PREFIX="/api"

# WebSocket
WS_PORT=3001

# Chat AI (OpenAI Responses API or a compatible endpoint)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
MODEL_NAME="gpt-4.1-mini"
AI_API_MODE="auto"
AI_TIMEOUT_MS=30000
AI_MAX_INPUT_CHARACTERS=30000
AI_RATE_LIMIT_WINDOW_MS=5000

# Queue
BULL_REDIS_URL="redis://localhost:6379"
