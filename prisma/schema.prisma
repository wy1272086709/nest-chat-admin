
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL") // 手动指定影子库地址
}

// ===== 枚举定义 =====
enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AUDIO
  VIDEO
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

// ===== 聊天用户模型 =====
model ChatUser {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  nickname      String
  passwordHash  String
  avatarUrl     String?
  bio           String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 聊天状态
  status        UserStatus @default(ACTIVE)

  // 聊天关系
  sentMessages    Message[] @relation("MessageSender")
  receivedMessages MessageRecipient[]
  createdRooms    ChatRoom[] @relation("RoomCreator")
  roomMembers     RoomMember[]
  ownedRooms      ChatRoom[] @relation("RoomOwner")
  uploadedFiles   FileStorage[]
  articles        Article[]  // 用户发表的文章

  @@index([status, createdAt])
  @@map("chat_users")
}

// ===== 管理后台用户模型 =====
model AdminUser {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  avatarUrl     String?
  bio           String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // 状态和角色
  status        UserStatus @default(ACTIVE)
  role          Role       @relation(fields: [roleId], references: [id])
  roleId        String

  // 管理后台关系
  reviews       Review[]
  auditLogs     AuditLog[]

  @@index([status, createdAt])
  @@map("admin_users")
}

// 角色权限系统
model Role {
  id          String @id @default(cuid())
  name        String @unique
  description String?

  permissions Permission[]
  users       AdminUser[]

  @@map("roles")
}

model Permission {
  id        String @id @default(cuid())
  name      String
  resource  String
  action    String

  role      Role   @relation(fields: [roleId], references: [id])
  roleId    String

  @@unique([resource, action])
  @@map("permissions")
}

// ===== 管理后台模块 =====
model Article {
  id            String       @id @default(cuid())
  title         String
  content       String
  authorId      String
  status        ArticleStatus @default(DRAFT)
  isAiGenerated Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  publishedAt   DateTime?
  reviewedAt    DateTime?

  author        ChatUser     @relation(fields: [authorId], references: [id])
  reviews       Review[]
  @@map("articles")
}

model Review {
  id        String       @id @default(cuid())
  articleId String
  reviewerId String
  status    ReviewStatus
  comments  String?
  createdAt DateTime     @default(now())

  article   Article      @relation(fields: [articleId], references: [id])
  reviewer  AdminUser    @relation(fields: [reviewerId], references: [id])

  @@map("reviews")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  createdAt  DateTime @default(now())

  user       AdminUser     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ===== 聊天模块 =====
model ChatRoom {
  id            String       @id @default(cuid())
  name          String
  description   String?
  maxMembers    Int?
  createdBy     String
  ownerId       String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  creator       ChatUser     @relation("RoomCreator", fields: [createdBy], references: [id])
  owner         ChatUser     @relation("RoomOwner", fields: [ownerId], references: [id])
  messages      Message[]
  members       RoomMember[]

  // 管理员字段
  isArchived    Boolean      @default(false)  // 是否已归档
  topic         String?      // 群聊主题/目的

  @@map("chat_rooms")
}

model RoomMember {
  id           String           @id @default(cuid())
  roomId       String
  userId       String
  joinedAt     DateTime        @default(now())
  role         MemberRole      @default(MEMBER)
  status       MemberStatus    @default(ACTIVE)
  lastReadAt   DateTime?        // 最后阅读时间

  room         ChatRoom         @relation(fields: [roomId], references: [id])
  user         ChatUser         @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("room_members")
}

model Message {
  id           String      @id @default(cuid())
  roomId       String
  senderId     String
  content      String?
  messageType  MessageType  @default(TEXT)
  // 文件分享字段
  fileUrl      String?     // 文件访问URL
  fileName     String?     // 原始文件名
  fileSize     Int?        // 文件大小（字节）
  fileType     String?     // MIME类型
  // 其他字段
  isEdited     Boolean     @default(false)
  editedAt     DateTime?
  isDeleted    Boolean     @default(false) // 软删除
  deletedAt   DateTime?
  createdAt    DateTime    @default(now())

  room         ChatRoom    @relation(fields: [roomId], references: [id])
  sender       ChatUser    @relation("MessageSender", fields: [senderId], references: [id])
  recipients   MessageRecipient[]

  // 搜索索引（只存6个月内）
  searchIndex  MessageSearchIndex?

  @@index([roomId, createdAt])
  @@index([senderId, createdAt])
  @@map("messages")
}

// 消息接收状态
model MessageRecipient {
  id         String           @id @default(cuid())
  messageId  String
  userId     String
  status     MessageStatus    @default(SENT)
  readAt     DateTime?
  receivedAt DateTime         @default(now())

  message    Message          @relation(fields: [messageId], references: [id])
  user       ChatUser         @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_recipients")
}

// 消息搜索索引（性能优化）
model MessageSearchIndex {
  id        String   @id @default(cuid())
  messageId String   @unique
  content   String   // 用于搜索的内容
  createdAt DateTime

  message   Message  @relation(fields: [messageId], references: [id])

  @@index([content]) // 创建全文搜索索引
  @@map("message_search_index")
}

model FileStorage {
  id           String   @id @default(cuid())
  originalName String   // 原始文件名
  filename     String   // 存储文件名（UUID）
  mimetype     String   // MIME类型
  size         Int       // 文件大小（字节）
  path         String   // 文件存储路径
  url          String   // 公共访问URL
  uploadedBy   String
  createdAt    DateTime @default(now())

  uploader     ChatUser  @relation(fields: [uploadedBy], references: [id])

  @@index([mimetype, size])
  @@map("file_storage")
}

