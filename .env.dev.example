# 开发环境配置模板 —— 复制为 .env.dev 并填入真实值
# 用法: ./deploy.sh dev
# 说明: 应用以 --network host 运行,依赖(minio/redis/rabbitmq)由 docker-compose 起,
#       端口默认绑定 127.0.0.1,故这里主机名用 localhost 即可命中。

# Database (本地 postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nest_admin?schema=public

DB_SYNC=false
DB_LOGGING=true

# JWT (至少 32 字符)
JWT_EXPIRES_IN=2d
JWT_SECRET=replace-with-a-dev-secret-at-least-32-chars-long

# Redis (本地)
REDIS_URL=redis://:devredis@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=devredis
REDIS_DB=0

# MinIO (本地)
MINIO_HOST_BIND=127.0.0.1
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_SERVER_URL=http://localhost:9000
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# Email
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=20971520

# Server
PORT=3000
GLOBAL_PREFIX=api

# WebSocket
WS_PORT=3001

# Queue
BULL_REDIS_URL=redis://:devredis@localhost:6379

# Environment
NODE_ENV=development
SSL=false

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_HEALTH_LOG_ENABLED=false
LOG_DEPENDENCY_CHECK_INTERVAL_MS=30000
LOG_MAX_FILE_SIZE_MB=20
LOG_RETENTION_DAYS=30

# 依赖服务版本 tag
POSTGRES_VERSION_TAG=15
MINIO_VERSION_TAG=latest
REDIS_VERSION_TAG=7
RABBITMQ_VERSION_TAG=3-management

# 依赖服务默认账号(docker-compose 初始化 minio/rabbitmq 用)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123456

# AI 模型
MODEL_NAME=qwen-plus
OPENAI_API_KEY=
EMBEDDINGS_MODEL_NAME=text-embedding-v3
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_MODERATION_ENABLED=true
AI_MODERATION_MODEL=
AI_MODERATION_TIMEOUT_MS=5000
AI_MODERATION_MAX_CHARACTERS=4000
AI_MODERATION_MODE=async
AI_MODERATION_POLICY_VERSION=v1
AI_MODERATION_ACTIONS_ENABLED=true
AI_MODERATION_ENFORCEMENT_ENABLED=false
AI_MODERATION_VIOLATION_WINDOW_MS=86400000
AI_MODERATION_WARNING_SCORE=3
AI_MODERATION_MUTE_SCORE=6
AI_MODERATION_MUTE_DURATION_MS=600000
CHAT_MODERATION_PUBLISHER_ENABLED=true
CHAT_MODERATION_CONSUMER_ENABLED=true
CHAT_MODERATION_RETRY_DELAY_MS=10000
CHAT_MODERATION_MAX_RETRY=3
CHAT_MODERATION_PREFETCH=5
MODERATION_OUTBOX_POLL_MS=1000
MODERATION_OUTBOX_BATCH_SIZE=50
MODERATION_OUTBOX_LOCK_MS=30000
MODERATION_OUTBOX_MAX_ATTEMPTS=10
MODERATION_OUTBOX_RETENTION_DAYS=7
AI_RATE_LIMIT_WINDOW_MS=5000
AI_RATE_LIMIT_MAX_REQUESTS=1
ALLOWED_PATHS=
